{
"name": "@ngo-donor/api",
"version": "1.0.0",
"private": true,
"scripts": {
"build": "nest build",
"start": "node --max-old-space-size=512 dist/src/main.js",
"dev": "nest start --watch",
"start:prod": "node --max-old-space-size=512 dist/src/main.js",
"prisma:generate": "prisma generate --schema=prisma/schema.prisma",
