// ─── Central Task Engine ─────────────────────────────────────────

model Task {
  id                    String       @id @default(uuid())
  title                 String
  description           String?
  type                  TaskType
  status                TaskStatus   @default(PENDING)
  priority              TaskPriority @default(MEDIUM)
  dueDate               DateTime
  completedAt           DateTime?
  donorId               String?
  beneficiaryId         String?
  assignedTo            String?
  autoWhatsAppPossible  Boolean      @default(false)
  manualRequired        Boolean      @default(true)
  sourceOccasionId      String?
  sourceSponsorshipId   String?
  sourcePledgeId        String?
  sourceFamilyMemberId  String?
  contactCount          Int          @default(0)
  lastContactedAt       DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  donor           Donor?               @relation("TaskDonor", fields: [donorId], references: [id], onDelete: SetNull)
  beneficiary     Beneficiary?         @relation("TaskBeneficiary", fields: [beneficiaryId], references: [id], onDelete: SetNull)
  assignedUser    User?                @relation("TaskAssignedUser", fields: [assignedTo], references: [id], onDelete: SetNull)
  sourceOccasion  DonorSpecialOccasion? @relation("TaskSourceOccasion", fields: [sourceOccasionId], references: [id], onDelete: SetNull)
  sourceSponsorship Sponsorship?       @relation("TaskSourceSponsorship", fields: [sourceSponsorshipId], references: [id], onDelete: SetNull)
  sourcePledge    Pledge?              @relation("TaskSourcePledge", fields: [sourcePledgeId], references: [id], onDelete: SetNull)
  sourceFamilyMember DonorFamilyMember? @relation("TaskSourceFamilyMember", fields: [sourceFamilyMemberId], references: [id], onDelete: SetNull)
  contactLogs     CommunicationLog[]   @relation("CommunicationLogTask")

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([dueDate])
  @@index([donorId])
  @@index([beneficiaryId])
  @@index([assignedTo])
  @@index([status, dueDate])
  @@index([sourceOccasionId])
  @@index([sourceSponsorshipId])
  @@index([sourcePledgeId])
  @@index([sourceFamilyMemberId])
  @@map("tasks")
}

