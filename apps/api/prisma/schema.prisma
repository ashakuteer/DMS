generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @default(uuid())
  email             String                  @unique
  username          String?                 @unique
  password          String
  name              String
  role              Role                    @default(STAFF)
  phone             String?                 @unique
  isActive          Boolean                 @default(true)
  refreshToken           String?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  auditLogs         AuditLog[]
  beneficiaries     Beneficiary[]
  campaigns         Campaign[]
  communicationLogs CommunicationLog[]      @relation("CommunicationSentBy")
  createdTemplates  CommunicationTemplate[] @relation("TemplateCreatedBy")
  updatedTemplates  CommunicationTemplate[] @relation("TemplateUpdatedBy")
  donations         Donation[]

  // ✅ Donors assigned/owned by this user
  assignedDonors    Donor[]                 @relation("DonorAssignedToUser")

  createdDonors              Donor[]                  @relation("CreatedByDonors")
  sentEmails                 EmailLog[]               @relation("EmailSentBy")
  pledges                    Pledge[]
  reminders                  Reminder[]               @relation("ReminderCreatedBy")
  reminderTasks              ReminderTask[]           @relation("ReminderTaskCreatedBy")
  beneficiaryUpdates         BeneficiaryUpdate[]      @relation("BeneficiaryUpdateCreatedBy")
  createdMetrics             BeneficiaryMetric[]      @relation("MetricCreatedBy")
  createdProgressCards       ProgressCard[]           @relation("ProgressCardCreatedBy")
  createdHealthEvents        BeneficiaryHealthEvent[] @relation("HealthEventCreatedBy")
  createdDocuments           Document[]               @relation("DocumentCreatedBy")
  documentAccessLogs         DocumentAccessLog[]      @relation("DocumentAccessBy")
  createdReportCampaigns     ReportCampaign[]         @relation("ReportCampaignCreatedBy")
  outboundMessages           OutboundMessageLog[]     @relation("OutboundMessageCreatedBy")
  updatedTemplates2          MessageTemplate[]        @relation("MessageTemplateUpdatedBy")
  createdMilestones          Milestone[]              @relation("MilestoneCreatedBy")
  timeMachineEntries         TimeMachineEntry[]       @relation("TimeMachineCreatedBy")
  createdBackups             DataBackup[]             @relation("BackupCreatedBy")
  sponsorshipStatusChanges   SponsorshipStatusHistory[]
  createdDonorUpdates        DonorUpdate[]            @relation("DonorUpdateCreatedBy")
  generatedDonorReports      DonorReport[]            @relation("DonorReportGeneratedBy")
  createdReportTemplates     DonorReportTemplate[]    @relation("ReportTemplateCreatedBy")
  generatedProgressReports   BeneficiaryProgressReport[] @relation("ProgressReportGeneratedBy")
  createdCampaignUpdates     CampaignUpdate[]         @relation("CampaignUpdateCreatedBy")
  assignedFollowUps          FollowUpReminder[]       @relation("FollowUpAssignedTo")
  createdFollowUps           FollowUpReminder[]       @relation("FollowUpCreatedBy")
  uploadedNgoDocs            NgoDocument[]            @relation("NgoDocUploadedBy")
  uploadedNgoDocVersions     NgoDocumentVersion[]     @relation("NgoDocVersionUploadedBy")
  ngoDocAccessLogs           NgoDocumentAccessLog[]   @relation("NgoDocAccessBy")
  assignedTasks              StaffTask[]              @relation("TaskAssignedTo")
  createdTasks               StaffTask[]              @relation("TaskCreatedBy")
  centralTasks               Task[]                   @relation("TaskAssignedUser")
  performanceSnapshots       StaffPerformance[]       @relation("StaffPerformanceUser")
  communicationMessages      CommunicationMessage[]   @relation("CommunicationMessageCreatedBy")

  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

model Donor {
  id                 String                 @id @default(uuid())
  donorCode          String                 @unique
  firstName          String
  middleName         String?
  lastName           String?
  primaryPhone       String?
  primaryPhoneCode   String?                @default("+91")
  alternatePhone     String?
  alternatePhoneCode String?                @default("+91")
  whatsappPhone      String?
  whatsappPhoneCode  String?                @default("+91")
  personalEmail      String?
  officialEmail      String?
  address            String?
  city               String?
  state              String?
  country            String?                @default("India")
  pincode            String?
  profession         String?
  visited            Boolean                @default(false)
  approximateAge     Int?
  gender             Gender?
  incomeSpectrum     IncomeSpectrum?
  religion           String?
  donationMethods    DonationMethod[]
  donationFrequency  DonationFrequency?
  notes              String?
  prefEmail          Boolean                @default(true)
  prefWhatsapp       Boolean                @default(true)
  prefSms            Boolean                @default(false)
  prefReminders      Boolean                @default(true)
  timezone           String                 @default("Asia/Kolkata")
  category           DonorCategory          @default(INDIVIDUAL)
  isUnder18Helper    Boolean                @default(false)
  isSeniorCitizen    Boolean                @default(false)
  isSingleParent     Boolean                @default(false)
  isDisabled         Boolean                @default(false)
  sourceOfDonor      SourceOfDonor?
  sourceDetails      String?
  pan                String?
  profilePicUrl      String?
  supportPreferences SupportPreference[]

  primaryRole        PersonRole             @default(INDIVIDUAL)
  additionalRoles    PersonRole[]
  donorTags          String[]
  languages          String[]               @default([])
  preferredHomes     String[]               @default([])
  primaryHomeInterest String?
  communicationChannels         String[]
  preferredCommunicationMethod  String?
  communicationNotes            String?

  engagementLevel    DonorEngagement        @default(WARM)
  referredByDonorId  String?
  createdById        String
  isDeleted          Boolean                @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  deleteReason       String?
  donorSince         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  dobDay             Int?
  dobMonth           Int?
  healthScore        Int                    @default(100)
  healthStatus       HealthStatus           @default(GREEN)
  lastHealthCheck    DateTime?

  // ✅ One owner (staff user) for follow-ups
  assignedToUserId   String?
  assignedToUser     User?                  @relation("DonorAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  // relations
  communicationLogs  CommunicationLog[]
  donations          Donation[]
  familyMembers      DonorFamilyMember[]
  specialOccasions   DonorSpecialOccasion[]

  createdBy          User                   @relation("CreatedByDonors", fields: [createdById], references: [id])
  referredBy         Donor?                 @relation("DonorReferrals", fields: [referredByDonorId], references: [id])
  referrals          Donor[]                @relation("DonorReferrals")

  emailLogs          EmailLog[]
  emailJobs          EmailJob[]
  pledges            Pledge[]
  reminders          Reminder[]
  reminderTasks      ReminderTask[]         @relation("ReminderTaskDonor")
  sponsorships       Sponsorship[]
  sponsorUpdateDispatches SponsorUpdateDispatch[]
  sponsorshipReminders   SponsorshipReminder[] @relation("SponsorshipReminderDonor")
  outboundMessages       OutboundMessageLog[]  @relation("OutboundMessageDonor")
  donorUpdateDispatches  DonorUpdateDispatch[]
  donorReports           DonorReport[]         @relation("DonorReportForDonor")
  campaignUpdateDispatches CampaignUpdateDispatch[]
  followUpReminders      FollowUpReminder[]
  linkedTasks            StaffTask[]           @relation("TaskLinkedDonor")
  communicationMessages  CommunicationMessage[] @relation("CommunicationMessageDonor")
  tasks                  Task[]                @relation("TaskDonor")

  individualProfile      IndividualDonorProfile?
  volunteerProfile       VolunteerProfile?
  influencerProfile      InfluencerProfile?
  csrProfile             CSRProfile?

  @@index([primaryRole])
  @@index([primaryPhone])
  @@index([dobMonth, dobDay])
  @@index([personalEmail])
  @@index([officialEmail])
  @@index([donorCode])
  @@index([assignedToUserId])
  @@index([isDeleted])
  @@index([isDeleted, createdAt])
  @@index([isDeleted, category])
  @@index([isDeleted, city])
  @@index([isDeleted, healthStatus])
  @@index([whatsappPhone])
  @@index([firstName, lastName])
  @@index([healthScore])
  // ✅ Phase 1: Performance indexes
  @@index([isDeleted, donationFrequency])
  @@index([isDeleted, updatedAt])
  // ✅ Phase 2: deletedAt indexes (services filter deletedAt: null, not isDeleted)
  @@index([deletedAt])
  @@index([deletedAt, donationFrequency])
  @@map("donors")
}
model DonorSpecialOccasion {
  id                String         @id @default(uuid())
  donorId           String
  type              OccasionType
  relatedPersonName String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  month             Int
  day               Int
  donor             Donor          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  reminderTasks     ReminderTask[] @relation("ReminderTaskSourceOccasion")
  actionTasks       Task[]         @relation("TaskSourceOccasion")

  @@index([donorId])
  @@map("donor_special_occasions")
}

model DonorFamilyMember {
  id            String             @id @default(uuid())
  donorId       String
  relationType  FamilyRelationType
  name          String
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  email         String?
  phone         String?
  birthMonth    Int?
  birthDay      Int?
  donor         Donor              @relation(fields: [donorId], references: [id], onDelete: Cascade)
  reminderTasks ReminderTask[]     @relation("ReminderTaskSourceFamily")
  tasks         Task[]             @relation("TaskSourceFamilyMember")

  @@index([donorId])
  @@map("donor_family_members")
}

model Donation {
  id                String             @id @default(uuid())
  donorId           String
  donationDate      DateTime
  donationAmount    Decimal            @db.Decimal(15, 2)
  currency          String             @default("INR")
  donationType      DonationType       @default(CASH)
  donationMode      DonationMode?
  donationPurpose   DonationPurpose?
  donationCategory  String?
donationOccasion  String?
scheduleType      String?
  transactionId     String?
  remarks           String?
  quantity          Decimal?           @db.Decimal(10, 2)
  unit              String?
  itemDescription   String?
  kindCategory      KindCategory?
  kindDescription   String?
  donationHomeType  DonationHomeType?
  homeId            String?
  visitedHome       Boolean            @default(false)
  servedFood        Boolean            @default(false)
  receiptNumber     String?
  financialYear     String?
  receiptPdfUrl     String?
  attachmentUrl     String?
  createdById       String
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  campaignId        String?
  communicationLogs CommunicationLog[]
  campaign          Campaign?          @relation(fields: [campaignId], references: [id])
  createdBy             User               @relation(fields: [createdById], references: [id])
  donor                 Donor              @relation(fields: [donorId], references: [id])
  home                  Beneficiary?       @relation(fields: [homeId], references: [id])
  emailLogs             EmailLog[]
  reminders             Reminder[]
  fulfilledPledge       Pledge?            @relation("PledgeFulfilledByDonation")
  sponsorshipPayments   SponsorshipPayment[]

  @@index([donorId])
  @@index([donationDate])
  @@index([receiptNumber])
  @@index([financialYear])
  @@index([isDeleted])
  @@index([donationHomeType])
  // ✅ Phase 1: Performance indexes
  @@index([isDeleted, donationDate])
  @@index([donorId, isDeleted, donationDate])
  @@index([donationMode])
  @@index([donationType])
  // ✅ Phase 2: deletedAt indexes (services filter deletedAt: null, not isDeleted)
  @@index([deletedAt])
  @@index([deletedAt, donationDate])
  @@index([donorId, deletedAt, donationDate])
  @@map("donations")
}

model Pledge {
  id                        String       @id @default(uuid())
  donorId                   String
  pledgeType                PledgeType   @default(MONEY)
  amount                    Decimal?     @db.Decimal(15, 2)
  quantity                  String?
  currency                  String       @default("INR")
  promisedDate              DateTime?
  promisedMonth             Int?
  promisedDay               Int?
  expectedFulfillmentDate   DateTime
  status                    PledgeStatus @default(PENDING)
  notes                     String?
  fulfilledDonationId       String?      @unique
  createdById               String
  isDeleted                 Boolean      @default(false)
  deletedAt                 DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  createdBy                 User         @relation(fields: [createdById], references: [id])
  donor                     Donor        @relation(fields: [donorId], references: [id])
  fulfilledDonation         Donation?    @relation("PledgeFulfilledByDonation", fields: [fulfilledDonationId], references: [id])
  reminderTasks             ReminderTask[] @relation("ReminderTaskSourcePledge")
  actionTasks               Task[]       @relation("TaskSourcePledge")

  @@index([donorId])
  @@index([status])
  @@index([expectedFulfillmentDate])
  @@index([isDeleted])
  @@index([donorId, isDeleted, status])
  @@map("pledges")
}

model Campaign {
  id          String         @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  goalAmount  Decimal?       @db.Decimal(15, 2)
  currency    String         @default("INR")
  status      CampaignStatus @default(DRAFT)
  homeTypes   HomeType[]     @default([])
  createdById String
  isDeleted   Boolean        @default(false)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdBy   User           @relation(fields: [createdById], references: [id])
  donations   Donation[]
  beneficiaries CampaignBeneficiary[]
  updates     CampaignUpdate[]

  @@index([status])
  @@index([isDeleted])
  @@map("campaigns")
}

model CampaignBeneficiary {
  id            String      @id @default(uuid())
  campaignId    String
  beneficiaryId String
  notes         String?
  createdAt     DateTime    @default(now())
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@unique([campaignId, beneficiaryId])
  @@index([campaignId])
  @@index([beneficiaryId])
  @@map("campaign_beneficiaries")
}

model CampaignUpdate {
  id          String   @id @default(uuid())
  campaignId  String
  title       String
  content     String
  photoUrls   String[] @default([])
  createdById String
  createdAt   DateTime @default(now())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("CampaignUpdateCreatedBy", fields: [createdById], references: [id])
  dispatches  CampaignUpdateDispatch[]

  @@index([campaignId])
  @@index([createdAt])
  @@map("campaign_updates")
}

model CampaignUpdateDispatch {
  id              String                @id @default(uuid())
  campaignUpdateId String
  donorId         String
  channel         SponsorDispatchChannel
  status          SponsorDispatchStatus  @default(QUEUED)
  sentAt          DateTime?
  error           String?
  createdAt       DateTime              @default(now())
  campaignUpdate  CampaignUpdate        @relation(fields: [campaignUpdateId], references: [id], onDelete: Cascade)
  donor           Donor                 @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@index([campaignUpdateId])
  @@index([donorId])
  @@index([status])
  @@map("campaign_update_dispatches")
}

model Beneficiary {
  id                       String                     @id @default(uuid())
  code                     String                     @unique
  fullName                 String
  homeType                 HomeType
  category                 BeneficiaryCategory?
  gender                   Gender?
  dobDay                   Int?
  dobMonth                 Int?
  dobYear                  Int?
  approxAge                Int?
  joinDate                 DateTime?
  heightCmAtJoin           Int?
  weightKgAtJoin           Decimal?                   @db.Decimal(5, 2)
  educationClassOrRole     String?
  schoolOrCollege          String?
  healthNotes              String?
  currentHealthStatus      String?
  background               String?
  hobbies                  String?
  dreamCareer              String?
  favouriteSubject         String?
  favouriteGame            String?
  favouriteActivityAtHome  String?
  bestFriend               String?
  sourceOfPrideOrHappiness String?
  funFact                  String?
  additionalNotes          String?
  protectPrivacy           Boolean                    @default(false)
  photoUrl                 String?
  photoPath                String?
  status                   BeneficiaryStatus          @default(ACTIVE)
  createdById              String
  isDeleted                Boolean                    @default(false)
  deletedAt                DateTime?
  deletedBy                String?
  deleteReason             String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  createdBy                User                       @relation(fields: [createdById], references: [id])
  donations                Donation[]
  sponsorships             Sponsorship[]
  updates                  BeneficiaryUpdate[]
  timelineEvents           BeneficiaryTimelineEvent[]
  sponsorshipReminders     SponsorshipReminder[]      @relation("BeneficiaryReminders")
  metrics                  BeneficiaryMetric[]
  progressCards            ProgressCard[]
  healthEvents             BeneficiaryHealthEvent[]
  documents                Document[]
  progressReports          BeneficiaryProgressReport[]
  campaignBeneficiaries    CampaignBeneficiary[]
  tasks                    Task[]                     @relation("TaskBeneficiary")

  @@index([code])
  @@index([homeType])
  @@index([status])
  @@index([isDeleted])
  @@map("beneficiaries")
}

model Sponsorship {
  id                   String               @id @default(uuid())
  donorId              String
  beneficiaryId        String
  sponsorshipType      SponsorshipType
  amount               Decimal?             @db.Decimal(15, 2)
  currency             String               @default("INR")
  inKindItem           String?
  frequency            SponsorshipFrequency @default(ADHOC)
  startDate            DateTime?
  endDate              DateTime?
  dueDayOfMonth        Int?
  nextDueDate          DateTime?            @db.Date
  notes                String?
  isActive             Boolean              @default(true)
  status               SponsorshipStatus    @default(ACTIVE)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  donor                Donor                @relation(fields: [donorId], references: [id], onDelete: Cascade)
  beneficiary          Beneficiary          @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  sponsorshipReminders SponsorshipReminder[]
  payments             SponsorshipPayment[]
  statusHistory        SponsorshipStatusHistory[]
  actionTasks          Task[]               @relation("TaskSourceSponsorship")

  @@unique([donorId, beneficiaryId, sponsorshipType], name: "unique_active_sponsorship")
  @@index([donorId])
  @@index([beneficiaryId])
  @@index([isActive])
  @@index([status])
  @@index([nextDueDate])
  @@index([donorId, status])
  // ✅ Phase 1: Performance indexes
  @@index([isActive, status])
  @@index([frequency, dueDayOfMonth])
  @@index([isActive, frequency])
  @@map("sponsorships")
}

model SponsorshipStatusHistory {
  id              String            @id @default(uuid())
  sponsorshipId   String
  oldStatus       SponsorshipStatus
  newStatus       SponsorshipStatus
  oldAmount       Decimal?          @db.Decimal(15, 2)
  newAmount       Decimal?          @db.Decimal(15, 2)
  note            String?
  changedAt       DateTime          @default(now())
  changedById     String
  changedBy       User              @relation(fields: [changedById], references: [id], onDelete: Cascade)
  sponsorship     Sponsorship       @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)

  @@index([sponsorshipId])
  @@index([changedAt])
  @@map("sponsorship_status_history")
}

model SponsorshipPayment {
  id             String                    @id @default(uuid())
  sponsorshipId  String
  month          Int
  year           Int
  paidOn         DateTime?                 @db.Date
  amount         Decimal?                  @db.Decimal(15, 2)
  paymentMode    String?
  status         SponsorshipPaymentStatus  @default(DUE)
  donationId     String?
  notes          String?
  createdAt      DateTime                  @default(now())
  sponsorship    Sponsorship               @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  donation       Donation?                 @relation(fields: [donationId], references: [id])

  @@unique([sponsorshipId, month, year], name: "unique_sponsorship_month_year")
  @@index([sponsorshipId])
  @@index([donationId])
  @@index([year, month])
  @@index([status])
  @@map("sponsorship_payments")
}

model BeneficiaryUpdate {
  id            String                   @id @default(uuid())
  beneficiaryId String
  updateType    BeneficiaryUpdateType    @default(GENERAL)
  title         String
  content       String
  mediaUrls     String[]
  isPrivate     Boolean                  @default(false)
  shareWithDonor Boolean                 @default(false)
  createdById   String
  createdAt     DateTime                 @default(now())
  beneficiary   Beneficiary              @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  createdBy     User                     @relation("BeneficiaryUpdateCreatedBy", fields: [createdById], references: [id])
  dispatches    SponsorUpdateDispatch[]
  attachments   UpdateAttachment[]

  @@index([beneficiaryId])
  @@index([createdAt])
  @@map("beneficiary_updates")
}

model SponsorUpdateDispatch {
  id        String                      @id @default(uuid())
  updateId  String
  donorId   String
  channel   SponsorDispatchChannel
  status    SponsorDispatchStatus       @default(QUEUED)
  sentAt    DateTime?
  error     String?
  createdAt DateTime                    @default(now())
  update    BeneficiaryUpdate           @relation(fields: [updateId], references: [id], onDelete: Cascade)
  donor     Donor                       @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@index([updateId])
  @@index([donorId])
  @@index([status])
  @@map("sponsor_update_dispatches")
}

model SponsorshipReminder {
  id              String                      @id @default(uuid())
  sponsorshipId   String?
  beneficiaryId   String?
  donorId         String
  reminderType    SponsorshipReminderType
  dueDate         DateTime                    @db.Date
  status          SponsorshipReminderStatus   @default(PENDING)
  lastTriggeredAt DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  sponsorship     Sponsorship?                @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  beneficiary     Beneficiary?                @relation("BeneficiaryReminders", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  donor           Donor                       @relation("SponsorshipReminderDonor", fields: [donorId], references: [id], onDelete: Cascade)

  @@unique([sponsorshipId, reminderType, dueDate], name: "unique_sponsorship_reminder")
  @@unique([beneficiaryId, donorId, reminderType, dueDate], name: "unique_beneficiary_reminder")
  @@index([donorId])
  @@index([dueDate])
  @@index([status])
  @@map("sponsorship_reminders")
}

model BeneficiaryTimelineEvent {
  id            String                 @id @default(uuid())
  beneficiaryId String
  eventType     BeneficiaryEventType
  eventDate     DateTime
  description   String
  createdAt     DateTime               @default(now())
  beneficiary   Beneficiary            @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@index([beneficiaryId])
  @@index([eventDate])
  @@map("beneficiary_timeline_events")
}

model BeneficiaryMetric {
  id              String                   @id @default(uuid())
  beneficiaryId   String
  recordedOn      DateTime                 @default(now()) @db.Date
  heightCm        Int?
  weightKg        Decimal?                 @db.Decimal(5, 2)
  healthStatus    BeneficiaryHealthStatus  @default(NORMAL)
  notes           String?
  createdById     String
  createdAt       DateTime                 @default(now())
  beneficiary     Beneficiary              @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  createdBy       User                     @relation("MetricCreatedBy", fields: [createdById], references: [id])

  @@index([beneficiaryId])
  @@index([recordedOn])
  @@map("beneficiary_metrics")
}

model ProgressCard {
  id               String      @id @default(uuid())
  beneficiaryId    String
  academicYear     String
  term             ProgressTerm
  classGrade       String
  school           String?
  overallPercentage Decimal?   @db.Decimal(5, 2)
  remarks          String?
  fileDocumentId   String?
  createdById      String
  createdAt        DateTime    @default(now())
  beneficiary      Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  createdBy        User        @relation("ProgressCardCreatedBy", fields: [createdById], references: [id])
  fileDocument     Document?   @relation(fields: [fileDocumentId], references: [id])

  @@index([beneficiaryId])
  @@index([academicYear])
  @@map("progress_cards")
}

model BeneficiaryHealthEvent {
  id                 String             @id @default(uuid())
  beneficiaryId      String
  eventDate          DateTime           @db.Date
  title              String
  description        String
  severity           HealthEventSeverity @default(LOW)
  requiresDonorUpdate Boolean           @default(false)
  shareWithDonor     Boolean            @default(false)
  documentId         String?
  createdById        String
  createdAt          DateTime           @default(now())
  beneficiary        Beneficiary        @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  createdBy          User               @relation("HealthEventCreatedBy", fields: [createdById], references: [id])
  document           Document?          @relation(fields: [documentId], references: [id])

  @@index([beneficiaryId])
  @@index([eventDate])
  @@map("beneficiary_health_events")
}

model Document {
  id             String          @id @default(uuid())
  ownerType      DocumentOwnerType
  ownerId        String?
  docType        DocumentType
  title          String
  description    String?
  storageBucket  String
  storagePath    String
  mimeType       String
  sizeBytes      Int
  isSensitive    Boolean         @default(false)
  shareWithDonor Boolean         @default(false)
  createdById    String
  createdAt      DateTime        @default(now())
  beneficiary    Beneficiary?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  accessLogs     DocumentAccessLog[]
  progressCards  ProgressCard[]
  updateAttachments UpdateAttachment[]
  reportCampaigns ReportCampaign[]
