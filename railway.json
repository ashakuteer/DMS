{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPath": "apps/api"
  },
  "deploy": {
    "startCommand": "./node_modules/.bin/prisma db push --schema=prisma/schema.prisma --accept-data-loss --skip-generate && node --max-old-space-size=512 dist/src/main.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
